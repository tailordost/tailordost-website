---
import '../styles/globals.css';
import { siteConfig } from '../config.ts';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>Boutiques | {siteConfig.site.name}</title>
    <meta name="description" content="Explore boutiques listed on TailorDost near you." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <!-- Leaflet CSS -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      crossorigin=""
    />
  </head>

  <body class="font-sans antialiased">
    <Navigation />

    <section class="bg-mono-lighter min-h-screen px-4 pt-24 pb-20 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-10 text-center">
          <h1 class="text-mono-black mb-3 text-4xl font-extrabold sm:text-5xl">
            Our Boutiques
          </h1>
          <p class="text-mono-dark mx-auto max-w-2xl text-lg">
            Discover tailoring boutiques powered by TailorDost across India
          </p>
        </div>

        <!-- View Toggle -->
        <div class="mb-8 flex justify-center gap-2">
          <button
            id="listViewBtn"
            class="rounded-lg px-5 py-2 text-sm font-semibold text-white transition"
            style="background-color: #c0257a;"
          >
            List View
          </button>
          <button
            id="mapViewBtn"
            class="text-mono-dark rounded-lg border border-gray-300 bg-white px-5 py-2 text-sm font-semibold transition hover:bg-gray-50"
          >
            Map View
          </button>
        </div>

        <!-- Loading State -->
        <div id="loadingState" class="py-20 text-center">
          <div class="text-mono-gray text-lg">Loading boutiques...</div>
        </div>

        <!-- Error State -->
        <div id="errorState" class="hidden py-20 text-center">
          <div class="text-red-600 text-lg">Failed to load boutiques. Please try again later.</div>
        </div>

        <!-- List View -->
        <div id="listView" class="hidden">
          <div id="boutiqueGrid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"></div>
        </div>

        <!-- Map View -->
        <div id="mapView" class="hidden">
          <div id="map" class="h-[600px] w-full rounded-xl border border-gray-200 shadow-sm"></div>
        </div>
      </div>
    </section>

    <Footer />

    <!-- Leaflet JS -->
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

    <script is:inline define:vars={{ apiUrl: siteConfig.boutiquesApi }}>
      document.addEventListener('DOMContentLoaded', () => {
        const listViewBtn = document.getElementById('listViewBtn');
        const mapViewBtn = document.getElementById('mapViewBtn');
        const listView = document.getElementById('listView');
        const mapView = document.getElementById('mapView');
        const loadingState = document.getElementById('loadingState');
        const errorState = document.getElementById('errorState');
        const boutiqueGrid = document.getElementById('boutiqueGrid');

        let map = null;
        let mapInitialized = false;
        let boutiques = [];

        // View toggle
        function showList() {
          listView.classList.remove('hidden');
          mapView.classList.add('hidden');
          listViewBtn.style.backgroundColor = '#c0257a';
          listViewBtn.classList.add('text-white');
          listViewBtn.classList.remove('text-mono-dark', 'border', 'border-gray-300', 'bg-white');
          mapViewBtn.style.backgroundColor = '';
          mapViewBtn.classList.remove('text-white');
          mapViewBtn.classList.add('text-mono-dark', 'border', 'border-gray-300', 'bg-white');
        }

        function showMap() {
          listView.classList.add('hidden');
          mapView.classList.remove('hidden');
          mapViewBtn.style.backgroundColor = '#c0257a';
          mapViewBtn.classList.add('text-white');
          mapViewBtn.classList.remove('text-mono-dark', 'border', 'border-gray-300', 'bg-white');
          listViewBtn.style.backgroundColor = '';
          listViewBtn.classList.remove('text-white');
          listViewBtn.classList.add('text-mono-dark', 'border', 'border-gray-300', 'bg-white');

          if (!mapInitialized) {
            initMap();
          } else {
            map.invalidateSize();
          }
        }

        listViewBtn.addEventListener('click', showList);
        mapViewBtn.addEventListener('click', showMap);

        function initMap() {
          map = L.map('map').setView([20.5937, 78.9629], 5); // Center on India
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
          }).addTo(map);

          const bounds = [];

          boutiques.forEach((b) => {
            const lat = b.locationLat;
            const lng = b.locationLng;
            if (lat && lng) {
              const marker = L.marker([lat, lng]).addTo(map);
              marker.bindPopup(
                '<div style="text-align:center;min-width:150px;">' +
                  (b.logo ? '<img src="' + b.logo + '" alt="" style="height:40px;margin:0 auto 8px;" />' : '') +
                  '<strong>' + (b.name || 'Boutique') + '</strong>' +
                  (b.locationAddress ? '<br/><span style="font-size:12px;color:#666;">' + b.locationAddress + '</span>' : '') +
                '</div>'
              );
              bounds.push([lat, lng]);
            }
          });

          if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [50, 50] });
          }

          mapInitialized = true;
        }

        function renderCards(data) {
          boutiqueGrid.innerHTML = '';
          if (data.length === 0) {
            boutiqueGrid.innerHTML = '<div class="col-span-full py-10 text-center text-gray-500">No boutiques found.</div>';
            return;
          }

          data.forEach((b) => {
            const card = document.createElement('div');
            card.className = 'rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md';

            const locationText = b.locationAddress || '';

            card.innerHTML =
              '<div class="mb-4 flex items-center gap-4">' +
                (b.logo
                  ? '<img src="' + b.logo + '" alt="' + (b.name || '') + '" class="h-14 w-14 rounded-full object-cover border border-gray-100" />'
                  : '<div class="flex h-14 w-14 items-center justify-center rounded-full text-xl font-bold text-white" style="background-color:#c0257a;">' + (b.name ? b.name.charAt(0).toUpperCase() : 'B') + '</div>') +
                '<div>' +
                  '<h3 class="text-lg font-bold text-gray-900">' + (b.name || 'Boutique') + '</h3>' +
                  (locationText ? '<p class="text-sm text-gray-500">' + locationText + '</p>' : '') +
                '</div>' +
              '</div>' +
              (b.phone ? '<p class="mt-2 text-sm text-gray-600">Phone: ' + b.phone + '</p>' : '');

            boutiqueGrid.appendChild(card);
          });
        }

        // Fetch boutiques
        fetch(apiUrl)
          .then((res) => {
            if (!res.ok) throw new Error('Network error');
            return res.json();
          })
          .then((data) => {
            boutiques = Array.isArray(data) ? data : (data.data || data.boutiques || []);
            loadingState.classList.add('hidden');
            renderCards(boutiques);
            showList();
          })
          .catch((err) => {
            console.error('Failed to fetch boutiques:', err);
            loadingState.classList.add('hidden');
            errorState.classList.remove('hidden');
          });
      });
    </script>
  </body>
</html>
