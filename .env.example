# Color theme selection
# Set to 'boutique' for the boutique palette or 'mono' for the monochrome palette.
# After changing this value restart the dev server (npm run dev) or rebuild.
COLOR_THEME=boutique

# Boutiques listing page — set this to enable the /boutiques page and nav link
# PUBLIC_BOUTIQUES_API=http://localhost:4000/api/botics/public-list
